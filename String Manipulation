// Uppercase 
public String uppercase(String text)
{
    String result ="";
    for(int i=0;i<text.length();i++)
    {
        char ch=text.charAt(i);
        if(ch>='a' && ch<='z')// a-z : 97-122
        {
            ch=(char)(ch-32);// uppercase=lowercase-32
        }
          result+=ch;
    }
    return result;
    //String newstring=text.toUpperCase();
    //return newstring;
}

//Lowercase
public String lowercase(String text)
{
    String result="";
    for(int i=0;i<text.length();i++)
    {
        char ch=text.charAt(i);
        if(ch>='A' && ch<='Z')// A-Z : 65-90
        {
            ch=(char)(ch+32);//lowercase=uppercase+32 
        }
        result+=ch;
    }
    return result;
    //String newstring=text.toLowerCase();
    //return newstring;
}

