//Searching of a substring
public void searchsubstring(String text,Scanner s)
{
    System.out.println("Enter the sub string to be found:");
    String substring = s.nextLine();
    
   int n= text.length();
    int m= substring.length();
    
    if (m>n)
    {
        System.out.println("Substring not found");
        return;
    }
    
    for(int i=0;i<=n-m;i++)
    {
        int j;
        for( j=0;j<m;j++)
        {
            if(text.charAt(i+j)!=substring.charAt(j))
            {
                break;
            }
        }
        if(j==m)
        {
            System.out.println("Substring  found");
            return;
        }
    }
    System.out.println("Substring not found");
    
    //boolean result=text.contains(substring);
    //System.out.println(result);
}




